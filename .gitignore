# Large vendored toolchain — re-fetchable, not tracked
# (Temurin JDK 8 -> tools/jdk8, ProGuard 7.4.2 -> tools/proguard)
/tools/jdk8/
/tools/proguard/

# Build output (regenerated by build.sh / test.sh)
/build/
/dist/
*.class
__pycache__/

# Emulator working tree: keep the tour infrastructure, ignore everything
# generated (screenshots, RMS state, sample vault, logs, ad-hoc scratch).
/tools/emu/*
!/tools/emu/BUGS.md
!/tools/emu/tour.sh
!/tools/emu/xvfb-tour.sh
!/tools/emu/capture.sh
!/tools/emu/microemulator.jar
!/tools/emu/device-e71.jar
!/tools/emu/device-e71/
!/tools/emu/lib/
!/tools/emu/tours/
